# Select one of: mock, openai-compatible, minimax, kimi, glm
AI_IDE_AGENT_PROVIDER=mock

# Generic provider settings. Prefer provider-specific API key variables below
# when switching between multiple hosted providers.
AI_IDE_AGENT_API_KEY=
AI_IDE_AGENT_BASE_URL=
# Try mock-model with the mock provider without an API key.
# Hosted examples: glm-4.7-flash, kimi-k2.6, MiniMax-M2.7.
AI_IDE_AGENT_MODEL=

# Provider-specific API key fallbacks.
MINIMAX_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=

# Local mock provider response for development and tests.
AI_IDE_AGENT_MOCK_RESPONSE="Render a transparent extension task lifecycle."
